@model WarehouseManagementSystem.Models.Shipment

@{
    ViewData["Title"] = "Create New Shipment";
}

<div class="container py-5">
    <div class="card shadow-sm p-4 border-0 rounded-4 mx-auto" style="max-width: 800px;">
        <h2 class="text-primary fw-semibold mb-4">@ViewData["Title"]</h2>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="TrackingNumber" class="form-label fw-semibold">Tracking Number</label>
                <input asp-for="TrackingNumber" class="form-control" placeholder="Enter tracking number" />
                <span asp-validation-for="TrackingNumber" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ShippingDate" class="form-label fw-semibold">Shipping Date</label>
                <input asp-for="ShippingDate" class="form-control" type="date" />
                <span asp-validation-for="ShippingDate" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Status" class="form-label fw-semibold">Order Status</label>
                <select asp-for="Status" class="form-select">
                    <option value="">Select Status</option>
                    <option value="Pending">Pending</option>
                    <option value="In Transit">In Transit</option>
                    <option value="Delivered">Delivered</option>
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="Notes" class="form-label fw-semibold">Notes</label>
                <textarea asp-for="Notes" class="form-control" placeholder="Enter notes"></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>
            <div class="d-grid gap-2 d-md-block">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-check-circle me-1"></i> Create Shipment
                </button>
                <button type="reset" class="btn btn-info ms-2 px-4">
                    <i class="bi bi-arrow-counterclockwise me-1"></i> Reset
                </button>
                <a asp-action="Index" class="btn btn-secondary ms-2 px-4">
                    <i class="bi bi-arrow-left-circle me-1"></i> Back to List
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
