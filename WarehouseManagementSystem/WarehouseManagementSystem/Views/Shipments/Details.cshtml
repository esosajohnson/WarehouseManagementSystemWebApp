@model WarehouseManagementSystem.Models.Shipment

@{
    ViewData["Title"] = "Shipment Details";
}

<div class="container py-5">
    <div class="card shadow-sm p-4 border-0 rounded-4 mx-auto" style="max-width: 800px;">
        <h2 class="text-primary fw-semibold mb-4">Shipment Details</h2>
        <dl class="row">
            <dt class="col-sm-3">Shipment ID</dt>
            <dd class="col-sm-9">@Model.ShipmentId</dd>
            <dt class="col-sm-3">Tracking Number</dt>
            <dd class="col-sm-9">@Model.TrackingNumber</dd>
            <dt class="col-sm-3">Shipping Date</dt>
            <dd class="col-sm-9">@Model.ShippingDate</dd>
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>
            <dt class="col-sm-3">Notes</dt>
            <dd class="col-sm-9">@Model.Notes</dd>
        </dl>
        <div class="mt-4">
            <a asp-action="Edit" asp-route-id="@Model.ShipmentId" class="btn btn-primary px-4 me-2">
                <i class="bi bi-pencil-square me-1"></i> Edit
            </a>
            <a asp-action="Index" class="btn btn-secondary px-4">
                <i class="bi bi-arrow-left-circle me-1"></i> Back to List
            </a>
            <a asp-controller="ShipmentItems"
               asp-action="Create"
               asp-route-shipmentId="@Model.ShipmentId"
               class="btn btn-primary float-end">
                <i class="bi bi-plus-circle me-1"></i> Add Item
            </a>
        </div>
    </div>
</div>