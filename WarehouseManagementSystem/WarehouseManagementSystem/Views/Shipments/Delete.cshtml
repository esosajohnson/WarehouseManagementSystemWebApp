@model WarehouseManagementSystem.Models.Shipment

@{
    ViewData["Title"] = "Delete Shipment";
}

<div class="container py-5">
    <div class="card shadow-sm p-4 border-0 rounded-4 mx-auto" style="max-width: 800px;">
        <h2 class="text-primary fw-semibold mb-4">@ViewData["Title"]</h2>
        <p class="lead">Are you sure you want to delete this shipment?</p>
        <dl class="row">
            <dt class="col-sm-3">Shipment ID</dt>
            <dd class="col-sm-9">@Model.ShipmentId</dd>
            <dt class="col-sm-3">Tracking Number</dt>
            <dd class="col-sm-9">@Model.TrackingNumber</dd>
            <dt class="col-sm-3">Shipping Date</dt>
            <dd class="col-sm-9">@Model.ShippingDate</dd>
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>
            <dt class="col-sm-3">Notes</dt>
            <dd class="col-sm-9">@Model.Notes</dd>
        </dl>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="ShipmentId" />
            <div class="d-grid gap-2 d-md-block">
                <button type="submit" class="btn btn-danger px-4">
                    <i class="bi bi-trash me-1"></i> Delete
                </button>
                <a asp-action="Index" class="btn btn-secondary px-4">
                    <i class="bi bi-arrow-left-circle me-1"></i> Back to List
                </a>
            </div>
        </form>
    </div>
</div>