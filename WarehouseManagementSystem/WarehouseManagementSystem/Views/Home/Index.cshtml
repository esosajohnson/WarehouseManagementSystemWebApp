@{
    ViewData["Title"] = "Home";
}

<div class="container-fluid">

    <h2 class="fw-bold mb-1">
        <i class="bi bi-speedometer2 me-2"></i>
        Warehouse Dashboard
    </h2>

    <p class="text-muted mb-4">
        Overview of warehouse activity and system operations.
    </p>

    <!-- ===== OVERVIEW ===== -->

    <h5 class="dashboard-section">Overview</h5>

    <div class="row g-3 mb-4">

        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-card">
                <div class="card-body dashboard-metric">

                    <i class="bi bi-box-seam text-primary"></i>

                    <div>
                        <span class="metric-label">Products</span>
                        <h5>@ViewData["TotalProducts"]</h5>
                    </div>

                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-card">
                <div class="card-body dashboard-metric">

                    <i class="bi bi-people-fill text-success"></i>

                    <div>
                        <span class="metric-label">Suppliers</span>
                        <h5>@ViewData["TotalSuppliers"]</h5>
                    </div>

                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-card">
                <div class="card-body dashboard-metric">

                    <i class="bi bi-tags-fill text-warning"></i>

                    <div>
                        <span class="metric-label">Categories</span>
                        <h5>@ViewData["TotalCategories"]</h5>
                    </div>

                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-card">
                <div class="card-body dashboard-metric">

                    <i class="bi bi-person-badge-fill text-info"></i>

                    <div>
                        <span class="metric-label">Employees</span>
                        <h5>@ViewData["TotalEmployees"]</h5>
                    </div>

                </div>
            </div>
        </div>

    </div>


    <!-- ===== INVENTORY ===== -->

    <h5 class="dashboard-section">Inventory</h5>

    <div class="row g-3 mb-4">

        <div class="col-xl-4 col-md-6">
            <div class="card dashboard-card text-center">

                <div class="card-body">

                    <i class="bi bi-bar-chart-line fs-3 text-warning"></i>

                    <h6 class="mt-2">Stock Levels</h6>

                    <h4>@ViewData["TotalStockLevels"]</h4>

                    <a class="btn btn-sm btn-warning w-100"
                       href="/StockLevels">View Stock</a>

                </div>

            </div>
        </div>

        <div class="col-xl-4 col-md-6">
            <div class="card dashboard-card text-center">

                <div class="card-body">

                    <i class="bi bi-geo-alt-fill fs-3 text-secondary"></i>

                    <h6 class="mt-2">Locations</h6>

                    <h4>@ViewData["TotalLocations"]</h4>

                    <a class="btn btn-sm btn-secondary w-100"
                       href="/Locations">Manage Locations</a>

                </div>

            </div>
        </div>

        <div class="col-xl-4 col-md-6">
            <div class="card dashboard-card text-center">

                <div class="card-body">

                    <i class="bi bi-arrow-left-right fs-3 text-danger"></i>

                    <h6 class="mt-2">Inventory Movements</h6>

                    <h4>@ViewData["InventoryTransactions"]</h4>

                    <a class="btn btn-sm btn-danger w-100"
                       href="/InventoryTransactions">View Transactions</a>

                </div>

            </div>
        </div>

    </div>


    <!-- ===== OPERATIONS ===== -->

    <h5 class="dashboard-section">Operations</h5>

    <div class="row g-3">

        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-card text-center">

                <div class="card-body">

                    <i class="bi bi-cart-check fs-3 text-primary"></i>

                    <h6 class="mt-2">Purchase Orders</h6>

                    <h4>@ViewData["TotalPurchaseOrders"]</h4>

                    <a class="btn btn-sm btn-primary w-100"
                       href="/PurchaseOrders">View Orders</a>

                </div>

            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-card text-center">

                <div class="card-body">

                    <i class="bi bi-journal-check fs-3 text-success"></i>

                    <h6 class="mt-2">Goods Receipts</h6>

                    <h4>@ViewData["TotalGoodsReceipts"]</h4>

                    <a class="btn btn-sm btn-success w-100"
                       href="/GoodsReceipts">View Receipts</a>

                </div>

            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-card text-center">

                <div class="card-body">

                    <i class="bi bi-truck fs-3 text-info"></i>

                    <h6 class="mt-2">Shipments</h6>

                    <h4>@ViewData["TotalOutbound"]</h4>

                    <a class="btn btn-sm btn-info w-100"
                       href="/Shipments">View Shipments</a>

                </div>

            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-card text-center">

                <div class="card-body">

                    <i class="bi bi-arrow-counterclockwise fs-3 text-danger"></i>

                    <h6 class="mt-2">Returns</h6>

                    <h4>@ViewData["TotalReturns"]</h4>

                    <a class="btn btn-sm btn-danger w-100"
                       href="/ReturnTransactions">View Returns</a>

                </div>

            </div>
        </div>

    </div>

</div>