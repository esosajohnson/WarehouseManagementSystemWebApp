@model WarehouseManagementSystem.Models.PurchaseOrderItem

@{
    ViewData["Title"] = "Add Item to Purchase Order";
}

<div class="container py-5">
    <div class="card shadow-sm border-0 rounded-4 p-4 mx-auto" style="max-width: 800px;">
        <h2 class="text-primary fw-semibold mb-4">@ViewData["Title"]</h2>
        <p class="text-muted">
            Adding item to Purchase Order #@Model.PurchaseOrderId
        </p>
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="PurchaseOrderId" />
            <div class="mb-3">
                <label asp-for="ProductId" class="form-label fw-semibold">Product</label>
                <select asp-for="ProductId" class="form-control" asp-items="ViewBag.ProductId">
                    <option value="">-- Select Product --</option>
                </select>
                <span asp-validation-for="ProductId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Quantity" class="form-label fw-semibold">Quantity</label>
                <input asp-for="Quantity" class="form-control" id="Quantity" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="UnitCost" class="form-label fw-semibold">Unit Cost</label>
                <input asp-for="UnitCost" class="form-control" id="UnitCost" />
                <span asp-validation-for="UnitCost" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="LineTotal" class="form-label fw-semibold">Line Total</label>
                <input asp-for="LineTotal" class="form-control" id="LineTotalDisplay" readonly />
                <span asp-validation-for="LineTotal" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-plus-circle me-1"></i> Create
            </button>
            <button type="reset" class="btn btn-info ms-2 px-4">
                <i class="bi bi-arrow-counterclockwise me-1"></i> Reset
            </button>
            <a asp-action="Index" class="btn btn-secondary ms-2 px-4">
                <i class="bi bi-arrow-left-circle me-1"></i> Back to Item List
            </a>
            <a asp-controller="PurchaseOrders" asp-action="Details" asp-route-id="@Model.PurchaseOrderId" class="btn btn-secondary float-end px-4">
                <i class="bi bi-arrow-left-circle me-1"></i> Back to Order Details
            </a>
        </form>  
    </div>   
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        function calculateLineTotal() {
            var quantity = parseFloat(document.getElementById('Quantity').value) || 0;
            var unitCost = parseFloat(document.getElementById('UnitCost').value) || 0;
            var lineTotal = quantity * unitCost;
            document.getElementById('LineTotalDisplay').value = lineTotal.toFixed(2);
        }
        document.getElementById('Quantity').addEventListener('input', calculateLineTotal);
        document.getElementById('UnitCost').addEventListener('input', calculateLineTotal);
    </script>
}
