@model IEnumerable<WarehouseManagementSystem.Models.PurchaseOrderItem>

@{
    ViewData["Title"] = "Purchase Order Items";
}

<div class="container">
    <div class="row pt-4">
        <div class="col-md-6">
            <h2 class="text-primary fw-semibold">@ViewData["Title"]</h2>
        </div>
        <div class="col-md-6 text-end">
            <a asp-controller="PurchaseOrders" asp-action="Index" class="btn btn-primary px-4">
                <i class="bi bi-arrow-left-circle me-1"></i> Back to Orders
            </a>
        </div>
    </div>
</div>

<div class="container">
    <div class="row">
        <div class="col-12">
            <p class="text-muted">
                View and modify the items associated with the selected purchase order. You can edit quantities, unit costs, or remove items as needed.
            </p>
        </div>
    </div>
    
</div>

<div class="container py-5">
    <div class="card shadow-sm border-0 rounded-4 p-4 mx-auto">
        @if (Model != null && Model.Any())
        {
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Product</th>
                        <th>Quantity</th>
                        <th>Unit Cost</th>
                        <th>Line Total</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Product?.Name</td>
                            <td>@item.Quantity</td>
                            <td>@item.UnitCost.ToString("C")</td>
                            <td>@item.LineTotal.ToString("C")</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.PurchaseOrderItemId" class="btn btn-sm btn-primary me-2">
                                    <i class="bi bi-pencil-square me-1"></i> Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.PurchaseOrderItemId" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash me-1"></i> Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">No items found for this purchase order.</p>
        }
    </div>
</div>
