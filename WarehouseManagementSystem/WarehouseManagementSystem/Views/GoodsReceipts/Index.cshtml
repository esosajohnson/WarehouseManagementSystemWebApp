@using WarehouseManagementSystem.Models;
@model IEnumerable<WarehouseManagementSystem.Models.GoodsReceipt>

@{
    ViewData["Title"] = "Goods Receipts";
}

@if (TempData ["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="container">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary fw-semibold">@ViewData["Title"]</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-action="Create" class="btn btn-primary px-4">
                <i class="bi bi-plus-circle me-1"></i> Create New Goods Receipt
            </a>
        </div>
    </div>
</div>

<div class="container mb-2">
    <div class="row">
        <div class="col-12">
            <p>
                Please ensure that all goods receipts are accurately recorded to maintain inventory integrity and facilitate smooth operations.
            </p>
        </div>
    </div>
</div>

<div class="container px-1">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-file-earmark-text display-4 text-muted mb-3"></i>
                    <h4 class="text-muted">No Goods Receipts Found</h4>
                    <p class="text-muted">Click the button above to create your first goods receipt.</p>
                    <a asp-action="Create" class="btn btn-primary mt-3">
                        <i class="bi bi-plus-circle me-1"></i> Create Goods Receipt
                    </a>
                </div>
            }
            else
            {
                <table class="table table-hover align-middle table-lg">
                    <thead class="table-light">
                        <tr>
                            <th>Receipt ID</th>
                            <th>Purchase Order</th>
                            <th>Supplier</th>
                            <th>Employee</th>
                            <th>Receipt Date</th>
                            <th>Reference Number</th>
                            <th>Status</th>
                            <th>Notes</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in Model)
                        {
                            <tr>
                                <td>@entry.GoodsReceiptId</td>
                                <td>@entry.PurchaseOrderId</td>
                                <td>@entry.Supplier?.Name</td>
                                <td>@entry.Employee?.FullName</td>
                                <td>@entry.ReceiptDate.ToShortDateString()</td>
                                <td>@entry.ReferenceNumber</td>
                                <td>
                                    @switch (entry.Status)
                                    {
                                        case WarehouseManagementSystem.Models.GoodsReceiptStatus.Pending:
                                            <span class="badge bg-warning text-dark">
                                                <i class="bi bi-hour glass-split me-1"></i> Pending
                                            </span>
                                            break;
                                        case WarehouseManagementSystem.Models.GoodsReceiptStatus.Received:
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle-fill me-1"></i> Received
                                            </span>
                                            break;
                                        case WarehouseManagementSystem.Models.GoodsReceiptStatus.Cancelled:
                                            <span class="badge bg-danger">
                                                <i class="bi bi-x-circle-fill me-1"></i> Cancelled
                                            </span>
                                            break;
                                    }
                                </td>
                                <td>@entry.Notes</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <a asp-action="Edit" asp-route-id="@entry.GoodsReceiptId"
                                               class="btn btn-outline-secondary btn-sm">
                                            <i class="bi bi-pencil-square"></i> Edit
                                        </a>
                                        <a asp-action="Details" asp-route-id="@entry.GoodsReceiptId"
                                               class="btn btn-outline-info btn-sm">
                                            <i class="bi bi-eye-fill"></i> Details
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@entry.GoodsReceiptId"
                                               class="btn btn-outline-danger btn-sm">
                                            <i class="bi bi-trash-fill"></i> Delete
                                        </a>
                                        <form asp-action="Receive" asp-route-id="@entry.GoodsReceiptId"
                                              method="post" class="m-0 p-0 d-flex">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-success btn-sm"
                                                @(entry.Status == GoodsReceiptStatus.Received ? "disabled" : "")>
                                                <i class="bi bi-check-circle-fill me-1"></i> Mark as Received
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>


<style>
    .table-lg td,
    .table-lg th {
        padding: 1rem 1.25rem;
    }
</style>