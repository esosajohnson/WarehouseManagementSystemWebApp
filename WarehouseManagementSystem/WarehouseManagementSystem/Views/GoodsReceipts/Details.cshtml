@model WarehouseManagementSystem.Models.GoodsReceipt

@{
    ViewData["Title"] = "Receipt Details";
}

<div class="container py-5">
    <div class="card shadow-sm border-0 rounded-4 p-4 mx-auto" style="max-width: 600px;">
        <h3 class="text-primary fw-semibold mb-4">@ViewData["Title"]</h3>
        <dl class="row mb-0">
            <dt class="col-sm-3">Receipt Date</dt>
            <dd class="col-sm-9">@Model.ReceiptDate</dd>
            <dt class="col-sm-3">Reference Number</dt>
            <dd class="col-sm-9">@Model.ReferenceNumber</dd>
            <dt class="col-sm-3">Notes</dt>
            <dd class="col-sm-9">@Model.Notes</dd>
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>
            <dt class="col-sm-3">Purchase Order</dt>
            <dd class="col-sm-9">@Model.PurchaseOrderId</dd>
            <dt class="col-sm-3">Employee</dt>
            <dd class="col-sm-9">@Model.Employee?.FullName</dd>
            <dt class="col-sm-3">Supplier</dt>
            <dd class="col-sm-9">@Model.Supplier?.Name</dd>
        </dl>
        <div class="mt-4">
            @if (Model.Status != "Received")
            {
                <a asp-controller="GoodsReceiptItems"
                   asp-action="Create"
                   asp-route-goodsReceiptId="@Model.GoodsReceiptId"
                   class="btn btn-primary ms-2 px-4">
                    <i class="bi bi-plus-circle me-1"></i> Add Item
                </a>
            }

            <a asp-action="Edit" asp-route-id="@Model.GoodsReceiptId" class="btn btn-primary px-4 ms-2">
                <i class="bi bi-pencil-square me-1"></i> Edit
            </a>
            <a asp-action="Index" class="btn btn-secondary ms-2 px-4">
                <i class="bi bi-arrow-left-circle me-1"></i> Back to List
            </a>
        </div>
    </div>
</div>

@if (Model.GoodsReceiptItems != null && Model.GoodsReceiptItems.Any())
{
    <table class="table table-sm table-bordered">
        <thead>
            <tr>
                <th>Product</th>
                <th>Quantity Received</th>
                <th>Location</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.GoodsReceiptItems)
            {
                <tr>
                    <td>@item.Product?.Name</td>
                    <td>@item.QuantityReceived</td>
                    <td>@item.Location?.Name</td>
                    <td>
                        <a asp-controller="GoodsReceiptItems"
                           asp-action="Edit"
                           asp-route-id="@item.GoodsReceiptItemId"
                           class="btn btn-sm btn-outline-secondary">
                            Edit
                        </a>
                        <a asp-controller="GoodsReceiptItems"
                           asp-action="Delete"
                           asp-route-id="@item.GoodsReceiptItemId"
                           class="btn btn-sm btn-outline-danger">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        No items added yet.
    </div>
}

