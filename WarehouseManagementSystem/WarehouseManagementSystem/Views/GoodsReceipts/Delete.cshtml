@model WarehouseManagementSystem.Models.GoodsReceipt

@{
    ViewData["Title"] = "Delete Goods Receipt";
}

<div>
    <div class="card shadow-sm border-0 rounded-4 p-4 mx-auto" style="max-width: 600px;">
        <h2 class="text-primary fw-semibold mb-4">@ViewData["Title"]</h2>
        <div class="alert alert-warning" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            Are you sure you want to delete this goods receipt?
        </div>
        <dl class="row">
            <dt class="col-sm-4">Receipt ID</dt>
            <dd class="col-sm-8">@Model.GoodsReceiptId</dd>
            <dt class="col-sm-4">Purchase Order ID</dt>
            <dd class="col-sm-8">@Model.PurchaseOrderId</dd>
            <dt class="col-sm-4">Supplier</dt>
            <dd class="col-sm-8">@Model.Supplier?.Name</dd>
            <dt class="col-sm-4">Employee</dt>
            <dd class="col-sm-8">@Model.Employee?.FullName</dd>
            <dt class="col-sm-4">Receipt Date</dt>
            <dd class="col-sm-8">@Model.ReceiptDate.ToShortDateString()</dd>
            <dt class="col-sm-4">Reference Number</dt>
            <dd class="col-sm-8">@Model.ReferenceNumber</dd>
        </dl>
        <form asp-action="DeleteConfirmed" method="post">
            <input type="hidden" asp-for="GoodsReceiptId" />
            <button type="submit" class="btn btn-danger px-4">
                <i class="bi bi-trash-fill me-1"></i> Delete
            </button>
            <a asp-action="Index" class="btn btn-secondary px-4 ms-2">
                <i class="bi bi-x-circle-fill me-1"></i>
                Cancel
            </a>
        </form>
    </div>
</div>
