<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WarehouseManagementSystem</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WarehouseManagementSystem.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

</head>
<body>
    <div class="d-flex">
        <nav class="sidebar">

            <div class="sidebar-header">
                <h4>WMS</h4>
            </div>

            <ul class="nav flex-column">

                <!-- Dashboard -->
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                       asp-controller="Dashboard" asp-action="Index">
                        <i class="bi bi-speedometer2"></i>
                        <span>Dashboard</span>
                    </a>
                </li>

                <!-- USER MANAGEMENT -->
                <li class="sidebar-section">User Management</li>

                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "UserManagement" ? "active" : "")"
                       asp-controller="UserManagement" asp-action="Index">
                        <i class="bi bi-people"></i>
                        <span>Manage Users</span>
                    </a>
                </li>

                <!-- INBOUND -->
                <li class="sidebar-section">Inbound</li>

                <li class="nav-item">
                    <a class="nav-link"
                       data-bs-toggle="collapse"
                       href="#inboundMenu">
                        <i class="bi bi-box-arrow-in-down"></i>
                        <span>Inbound</span>
                        <i class="bi bi-chevron-down dropdown-icon"></i>
                    </a>

                    <div class="collapse" id="inboundMenu">
                        <ul class="nav flex-column submenu">
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="PurchaseOrders" asp-action="Index">
                                    Purchase Orders
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="GoodsReceipts" asp-action="Index">
                                    Goods Receipts
                                </a>
                            </li>
                        </ul>
                    </div>
                </li>

                <!-- INVENTORY -->
                <li class="sidebar-section">Inventory</li>

                <li class="nav-item">
                    <a class="nav-link"
                       data-bs-toggle="collapse"
                       href="#inventoryMenu">
                        <i class="bi bi-box-seam"></i>
                        <span>Inventory</span>
                        <i class="bi bi-chevron-down dropdown-icon"></i>
                    </a>

                    <div class="collapse" id="inventoryMenu">
                        <ul class="nav flex-column submenu">

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Products" asp-action="Index">
                                    Products
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Locations" asp-action="Index">
                                    Locations
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Inventory" asp-action="Stock">
                                    Stock Overview
                                </a>
                            </li>

                        </ul>
                    </div>
                </li>

            </ul>

            <div class="sidebar-footer">
                <partial name="_LoginPartial" />
            </div>

        </nav>

        <div class="main-content flex-grow-1 p-4">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>

            <footer class="border-top text-muted mt-5 pt-3">
                <div class="container">
                    &copy; 2025 - WarehouseManagementSystem - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
