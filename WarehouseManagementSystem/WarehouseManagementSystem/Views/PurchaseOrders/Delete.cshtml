@model WarehouseManagementSystem.Models.PurchaseOrder

@{
    ViewData["Title"] = "Delete Purchase Order";
}

<div class="container py-5">
    <div class="card shadow-sm border-0 rounded-4 p-4 mx-auto" style="max-width: 600px;">
        <h3 class="text-primary fw-semibold mb-4">@ViewData["Title"]</h3>
        <h5 class="mb-4">Are you sure you want to delete this purchase order?</h5>
        <dl class="row mb-4">
            <dt class="col-sm-4 fw-semibold">Supplier</dt>
            <dd class="col-sm-8">@Model.Supplier?.Name</dd>
            <dt class="col-sm-4 fw-semibold">Order Date</dt>
            <dd class="col-sm-8">@Model.OrderDate.ToShortDateString()</dd>
            <dt class="col-sm-4 fw-semibold">Expected Date</dt>
            <dd class="col-sm-8">@Model.ExpectedDate?.ToShortDateString()</dd>
            <dt class="col-sm-4 fw-semibold">Order Status</dt>
            <dd class="col-sm-8">@Model.OrderStatus</dd>
            <dt class="col-sm-4 fw-semibold">Total Amount</dt>
            <dd class="col-sm-8">@Model.TotalAmount.ToString("C")</dd>
            <dt class="col-sm-4 fw-semibold">Notes</dt>
            <dd class="col-sm-8">@Model.Notes</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="PurchaseOrderId" />
            <button type="submit" class="btn btn-danger px-4">
                <i class="bi bi-trash me-1"></i> Delete
            </button>
            <a asp-action="Index" class="btn btn-secondary ms-2 px-4">
                <i class="bi bi-arrow-left-circle me-1"></i> Back to List
            </a>
        </form>
    </div>
</div>