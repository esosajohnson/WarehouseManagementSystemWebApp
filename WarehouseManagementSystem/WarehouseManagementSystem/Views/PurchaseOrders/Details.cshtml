@model WarehouseManagementSystem.Models.PurchaseOrder

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>PurchaseOrder</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.OrderDate)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.OrderDate)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ExpectedDate)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ExpectedDate)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.OrderStatus)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.OrderStatus)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.TotalAmount)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TotalAmount)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Notes)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Notes)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Supplier)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Supplier.SupplierId)
        </dd>
    </dl>
</div>
<div>
    <a asp-controller="PurchaseOrderItems"
       asp-action="Create"
       asp-route-purchaseOrderId="@Model.PurchaseOrderId"
       class="btn btn-sm btn-primary mb-3">
        <i class="bi bi-plus-circle me-1"></i> Add Item
    </a>
    <a asp-action="Edit" asp-route-id="@Model?.PurchaseOrderId">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>

@if (Model.PurchaseOrderItems != null && Model.PurchaseOrderItems.Any())
{
    <table class="table table-sm table-bordered">
        <thead>
            <tr>
                <th>Product</th>
                <th>Quantity</th>
                <th>Unit Price</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.PurchaseOrderItems)
            {
                <tr>
                    <td>@item.Product?.Name</td>
                    <td>@item.Quantity</td>
                    <td>@item.UnitCost</td>
                    <td>
                        <a asp-controller="PurchaseOrderItems"
                           asp-action="Edit"
                           asp-route-id="@item.PurchaseOrderItemId"
                           class="btn btn-sm btn-outline-secondary">
                            Edit
                        </a>
                        <a asp-controller="PurchaseOrderItems"
                           asp-action="Delete"
                           asp-route-id="@item.PurchaseOrderItemId"
                           class="btn btn-sm btn-outline-danger">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        No items added yet.
    </div>
}
