@model WarehouseManagementSystem.Models.PurchaseOrder

@{
    ViewData["Title"] = "Purchase Order Details";
}

<div class="container py-5">
    <div class="card shadow-sm border-0 rounded-4 p-4 mx-auto" style="max-width: 600px;">
        <h2 class="text-primary fw-semibold mb-4">@ViewData["Title"]</h2>
        <dl class="row">
            <dt class="col-sm-4">Order Date</dt>
            <dd class="col-sm-8">@Model.OrderDate.ToShortDateString()</dd>
            <dt class="col-sm-4">Expected Date</dt>
            <dd class="col-sm-8">@Model.ExpectedDate?.ToShortDateString()</dd>
            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">@Model.OrderStatus</dd>
            <dt class="col-sm-4">Total Amount</dt>
            <dd class="col-sm-8">@Model.TotalAmount.ToString("C")</dd>
            <dt class="col-sm-4">Supplier</dt>
            <dd class="col-sm-8">@Model.Supplier?.Name</dd>
        </dl>
        <div class="mt-4">
            <a asp-action="Edit" asp-route-id="@Model.PurchaseOrderId" class="btn btn-primary me-2">
                <i class="bi bi-pencil-square me-1"></i> Edit
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left-circle me-1"></i> Back to List
            </a>
            <a asp-controller="PurchaseOrderItems"
                asp-action="Create" asp-route-id="@Model.PurchaseOrderItems" class="btn btn-success float-end">
                <i class="bi bi-plus-circle me-1"></i> Add Item
            </a>
        </div>
    </div>
</div>

@if (Model.PurchaseOrderItems != null && Model.PurchaseOrderItems.Any())
{
    <div class="container mt-5">
        <h4 class="text-primary fw-semibold mb-4">
            Items in this Purchase Order
        </h4>
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Product</th>
                    <th>Quantity</th>
                    <th>Unit Cost</th>
                    <th>Line Total</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.PurchaseOrderItems)
                {
                    <tr>
                        <td>@item.Product?.Name</td>
                        <td>@item.Quantity</td>
                        <td>@item.UnitCost.ToString("C")</td>
                        <td>@item.LineTotal.ToString("C")</td>
                        <td>
                            <a asp-controller="PurchaseOrderItems" asp-action="Edit" asp-route-id="@item.PurchaseOrderItemId" 
                                class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil-square me-1"></i> Edit
                            </a>
                            <a asp-controller="PurchaseOrderItems" asp-action="Delete" asp-route-id="@item.PurchaseOrderItemId" 
                                class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash-fill me-1"></i> Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}